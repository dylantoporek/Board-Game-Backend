# Postgres connection string (e.g. from Neon: https://neon.tech)
# Use the *pooled* connection string on Vercel.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# Only needed if the frontend is hosted on a different origin than the API.
# FRONTEND_ORIGIN=https://your-frontend.vercel.app
